# StudioOS environment — copy to .env and adjust

# Core
STUDIOOS_ENV=dev
STUDIOOS_LOG_LEVEL=INFO

# Database (asyncpg DSN)
STUDIOOS_DATABASE_URL=postgresql+asyncpg://studioos:studioos@localhost:5433/studioos

# LLM providers
STUDIOOS_MINIMAX_API_KEY=sk-cp-xxx
STUDIOOS_MINIMAX_BASE_URL=https://api.minimax.io/v1
STUDIOOS_MINIMAX_MODEL=MiniMax-M2.7-highspeed
STUDIOOS_ANTHROPIC_API_KEY=
STUDIOOS_OPENAI_API_KEY=

# Runtime
STUDIOOS_SCHEDULER_TICK_SECONDS=1
STUDIOOS_OUTBOX_POLL_SECONDS=0.5
STUDIOOS_RUN_TIMEOUT_SECONDS=300

# API
STUDIOOS_API_HOST=0.0.0.0
STUDIOOS_API_PORT=8000
